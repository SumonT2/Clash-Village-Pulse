@model ClashVillagePulse.Application.DTOs.ClanPriorityTemplateDto

@{
    ViewData["Title"] = "Clan Priority Template";
}

<h1>@Model.ClanName - @Model.Section - Hall @Model.HallLevel</h1>

@if (TempData["SuccessMessage"] is string success)
{
    <div class="alert alert-success">@success</div>
}

@if (TempData["ErrorMessage"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<form asp-action="Save" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="villageId" value="@Model.VillageId" />
    <input type="hidden" name="section" value="@Model.Section" />
    <input type="hidden" name="hallLevel" value="@Model.HallLevel" />

    <table class="table table-sm table-bordered">
        <thead>
            <tr>
                <th>Type</th>
                <th>Item</th>
                <th>Current</th>
                <th>Village Rank</th>
                <th>Clan Rank</th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Items.Count; i++)
            {
                <tr>
                    <td>
                        @Model.Items[i].ItemType
                        <input type="hidden" name="items[@i].Section" value="@Model.Items[i].Section" />
                        <input type="hidden" name="items[@i].ItemType" value="@Model.Items[i].ItemType" />
                        <input type="hidden" name="items[@i].ItemDataId" value="@Model.Items[i].ItemDataId" />
                    </td>
                    <td>@Model.Items[i].ItemName</td>
                    <td>@Model.Items[i].CurrentLevelText</td>
                    <td>@(Model.Items[i].VillagePriorityRank?.ToString() ?? "-")</td>
                    <td>
                        <input type="number"
                               name="items[@i].PriorityRank"
                               min="1"
                               value="@Model.Items[i].ClanPriorityRank"
                               class="form-control form-control-sm" />
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <button class="btn btn-primary">Save Clan Template</button>
    <a asp-controller="Village" asp-action="Details" asp-route-id="@Model.VillageId" class="btn btn-secondary">Back</a>
</form>