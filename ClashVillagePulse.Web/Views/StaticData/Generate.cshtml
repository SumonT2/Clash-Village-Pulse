@model ClashVillagePulse.Application.DTOs.StaticDataGenerationRequest

<h2>Generate Static Data</h2>

<form method="post">
    <div>
        <label>Fingerprint</label>
        <input name="Fingerprint" style="width:500px" required />
    </div>

    <br />

    <h4>Select Targets</h4>

    <label>
        <input type="checkbox" name="Targets" value="buildings" checked />
        Buildings
    </label>

    <br />

    <label>
        <input type="checkbox" name="Targets" value="characters" />
        Characters
    </label>

    <br />

    <label>
        <input type="checkbox" name="Targets" value="heroes" />
        Heroes
    </label>

    <br />

    <label>
        <input type="checkbox" name="Targets" value="spells" />
        Spells
    </label>

    <br />

    <label>
        <input type="checkbox" name="Targets" value="pets" />
        Pets
    </label>

    <br />

    <label>
        <input type="checkbox" name="Targets" value="equipment" />
        Equipment
    </label>
    <br />
    <label>
        <input type="checkbox" name="Targets" value="texts" />
        Localization
    </label>
    <br />

    <label>
        <input type="checkbox" name="Targets" value="townhall-levels" checked />
        Town Hall / Builder Hall caps
    </label>
    <br />
    <label>
        <input type="checkbox" name="Targets" value="traps" />
        Traps
    </label>
    <br />
    <label>
        <input type="checkbox" name="Targets" value="guardians" />
        Guardians
    </label>

    <br />
    <label>
        <input type="checkbox" name="Targets" value="helpers" />
        Helpers
    </label>
    <br />
    <label>
        <input type="checkbox" name="Targets" value="fankit-images" />
        Fan Kit images
    </label>
    <div style="color:#666; font-size:.9rem; margin:.35rem 0 1rem 1.5rem; max-width:720px;">
        Downloads public Clash of Clans Fan Kit images, auto-matches them to normalized static items and levels,
        stores files under <code>wwwroot/images/static/fankit</code>, and writes reports under
        <code>wwwroot/images/static/fankit/_reports</code>.
    </div>

    <button type="submit">Generate</button>
</form>
