<!DOCTYPE html>
<html lang="en">
<head>
    @{
        var pageTitle = ViewData["Title"]?.ToString();
        pageTitle = string.IsNullOrWhiteSpace(pageTitle) ? "Clash Village Pulse" : $"{pageTitle} - Clash Village Pulse";
    }

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/tabler/css/tabler.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClashVillagePulse.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

        var homeClass = currentController == "Home" && currentAction == "Index" ? "nav-link active" : "nav-link";
        var privacyClass = currentController == "Home" && currentAction == "Privacy" ? "nav-link active" : "nav-link";
        var villagesClass = currentController == "Village" && currentAction == "Index" ? "nav-link active" : "nav-link";
        var clanVillagesClass = currentController == "Village" && currentAction == "Clan" ? "nav-link active" : "nav-link";
        var uploadClass = currentController == "VillageUpload" ? "nav-link active" : "nav-link";
        var staticDataClass = currentController == "StaticData" ? "nav-link active" : "nav-link";
    }

    <div class="page">
        <header class="navbar navbar-expand-md d-print-none">
            <div class="container-fluid app-shell-container">
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbar-menu"
                        aria-controls="navbar-menu"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <a class="navbar-brand navbar-brand-autodark pe-0 pe-md-3"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    Clash Village Pulse
                </a>

                <div class="navbar-nav flex-row order-md-last">
                    <partial name="_LoginPartial" />
                </div>

                <div class="collapse navbar-collapse" id="navbar-menu">
                    <div class="d-flex flex-column flex-md-row flex-fill align-items-stretch align-items-md-center">
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="@homeClass" asp-area="" asp-controller="Home" asp-action="Index">
                                    Home
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="@villagesClass" asp-controller="Village" asp-action="Index">
                                    My Villages
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="@clanVillagesClass" asp-controller="Village" asp-action="Clan">
                                    Clan Villages
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="@uploadClass" asp-controller="VillageUpload" asp-action="Index">
                                    Upload Village
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="@staticDataClass" asp-controller="StaticData" asp-action="Generate">
                                    Generate Static Data
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="@privacyClass" asp-area="" asp-controller="Home" asp-action="Privacy">
                                    Privacy
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </header>

        <div class="page-wrapper">
            <div class="page-header d-print-none">
                <div class="container-fluid app-shell-container">
                    <div class="row g-2 align-items-center">
                        <div class="col">
                            <h2 class="page-title">@ViewData["Title"]</h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="page-body">
                <div class="container-fluid app-shell-container">
                    <main role="main" class="pb-3">
                        @RenderBody()
                    </main>
                </div>
            </div>

            <footer class="footer footer-transparent d-print-none">
                <div class="container-fluid app-shell-container">
                    <div class="row text-center align-items-center flex-row-reverse">
                        <div class="col-12 col-lg-auto mt-3 mt-lg-0">
                            &copy; 2026 - Clash Village Pulse
                        </div>
                        <div class="col-12 col-lg-auto mt-3 mt-lg-0">
                            <ul class="list-inline list-inline-dots mb-0">
                                <li class="list-inline-item">
                                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="link-secondary">
                                        Privacy
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/tabler/js/tabler.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>