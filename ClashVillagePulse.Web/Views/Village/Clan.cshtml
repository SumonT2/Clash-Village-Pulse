@model IReadOnlyList<ClashVillagePulse.Application.DTOs.VillageListItemDto>

@{
    ViewData["Title"] = "Clan Villages";
}

<h1>Clan Villages</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">No clan-linked villages are visible to you yet.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Owner</th>
                <th>Player Tag</th>
                <th>Clan</th>
                <th>Last Uploaded (UTC)</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var village in Model)
            {
                var ownerName = village.OwnerDisplayName ?? "-";
                var clanText = string.IsNullOrWhiteSpace(village.ClanName)
                ? "No clan"
                : string.IsNullOrWhiteSpace(village.ClanTag)
                ? village.ClanName
                : $"{village.ClanName} ({village.ClanTag})";

                <tr>
                    <td>@village.Name</td>
                    <td>@ownerName</td>
                    <td>@village.PlayerTag</td>
                    <td>@clanText</td>
                    <td>@village.LastUploadedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@village.Id" class="btn btn-sm btn-outline-primary">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}