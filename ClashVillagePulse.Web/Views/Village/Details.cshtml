                                                <div class="mt-4">
                                                    <div class="fw-semibold mb-2">Priority Suggestion</div>

                                                    @if (!item.HasPendingSuggestion)
                                                    {
                                                        <form asp-controller="PrioritySuggestion" asp-action="Create" method="post">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="VillageId" value="@Model.Id" />
                                                            <input type="hidden" name="Section" value="@item.Section" />
                                                            <input type="hidden" name="ItemType" value="@item.ItemType" />
                                                            <input type="hidden" name="ItemDataId" value="@item.ItemDataId" />

                                                            <div class="d-flex flex-column gap-2">
                                                                <div class="suggestion-note">
                                                                    Add a short note. The app will place this suggestion after the current queue.
                                                                </div>

                                                                <textarea name="Message"
                                                  class="form-control form-control-sm"
                                                  rows="2"
                                                  required
                                                  placeholder="Why should this item be moved up?"></textarea>

                                                                <button class="btn btn-sm btn-outline-primary">
                                                                    Suggest Item
                                                                </button>
                                                            </div>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-yellow-lt text-yellow">Already has a pending suggestion</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}

@section Scripts {
    <script>
        (function () {
            const detailSearch = document.getElementById('detail-search');

            function formatCountdown(diffMs) {
                if (diffMs <= 0) {
                    return "Completed";
                }

                let totalSeconds = Math.floor(diffMs / 1000);
                const days = Math.floor(totalSeconds / 86400);
                totalSeconds -= days * 86400;
                const hours = Math.floor(totalSeconds / 3600);
                totalSeconds -= hours * 3600;
                const minutes = Math.floor(totalSeconds / 60);
                const seconds = totalSeconds - minutes * 60;

                const hh = String(hours).padStart(2, '0');
                const mm = String(minutes).padStart(2, '0');
                const ss = String(seconds).padStart(2, '0');

                if (days > 0) {
                    return `${days}d ${hh}:${mm}:${ss}`;
                }

                return `${hh}:${mm}:${ss}`;
            }

            function tickCountdowns() {
                document.querySelectorAll('.live-countdown').forEach(function (el) {
                    const finishUtc = el.getAttribute('data-finish-utc');
                    if (!finishUtc) {
                        return;
                    }

                    const finishAt = new Date(finishUtc).getTime();
                    const now = Date.now();
                    const diff = finishAt - now;

                    el.textContent = formatCountdown(diff);
                });
            }

            function applyDetailSearch() {
                const term = (detailSearch?.value || '').trim().toLowerCase();

                document.querySelectorAll('.detail-card-col').forEach(function (el) {
                    const haystack = (el.getAttribute('data-search-text') || '').toLowerCase();
                    const matches = term === '' || haystack.includes(term);
                    el.classList.toggle('is-filtered-out', !matches);
                });

                document.querySelectorAll('.detail-search-row').forEach(function (el) {
                    const haystack = (el.getAttribute('data-search-text') || '').toLowerCase();
                    const matches = term === '' || haystack.includes(term);
                    el.classList.toggle('is-filtered-out', !matches);
                });

                document.querySelectorAll('[data-search-card="cards"]').forEach(function (section) {
                    const visibleCount = section.querySelectorAll('.detail-card-col:not(.is-filtered-out)').length;
                    section.classList.toggle('d-none', visibleCount === 0);
                });

                document.querySelectorAll('[data-search-card="table"]').forEach(function (section) {
                    const visibleCount = section.querySelectorAll('.detail-search-row:not(.is-filtered-out)').length;
                    section.classList.toggle('d-none', visibleCount === 0);
                });
            }

            if (detailSearch) {
                detailSearch.addEventListener('input', applyDetailSearch);
            }

            tickCountdowns();
            applyDetailSearch();
            setInterval(tickCountdowns, 1000);
        })();
    </script>
}